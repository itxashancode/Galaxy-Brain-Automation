# ─────────────────────────────────────────────────────────────────────────────
# Galaxy Brain Bot - Environment Configuration Example
# Copy this file to .env and fill in your credentials
# ─────────────────────────────────────────────────────────────────────────────

# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=your_github_username

# OpenRouter API Keys (comma-separated for key rotation)
OPENROUTER_KEYS=sk-or-v1-key1,sk-or-v1-key2

# OpenRouter Model List (Comma-separated)
# Leave blank to use defaults
OPENROUTER_MODELS=nvidia/nemotron-3-super-120b-a12b:free,arcee-ai/trinity-large-preview:free,z-ai/glm-4.5-air:free,openai/gpt-oss-120b:free,nvidia/nemotron-3-nano-30b-a3b:free,minimax/minimax-m2.5:free,google/gemma-4-31b-it:free,nvidia/nemotron-nano-9b-v2:free,nvidia/nemotron-nano-12b-v2-vl:free,google/gemma-4-26b-a4b-it:free,openai/gpt-oss-20b:free,nvidia/llama-nemotron-embed-vl-1b-v2:free,qwen/qwen3-coder:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free,liquid/lfm-2.5-1.2b-thinking:free,liquid/lfm-2.5-1.2b-instruct:free,google/gemma-3-27b-it:free,cognitivecomputations/dolphin-mistral-24b-venice-edition:free,meta-llama/llama-3.2-3b-instruct:free,google/gemma-3-4b-it:free,google/gemma-3-12b-it:free,google/gemma-3n-e2b-it:free,google/gemma-3n-e4b-it:free

# Rate Limit Settings
RATE_LIMIT_RETRY_AFTER=600
RATE_LIMIT_ROTATE_AFTER=300
MODEL_ATTEMPT_DELAY=5
PAGE_FETCH_DELAY=5

# Answer Quality Settings
ANSWER_MIN_CHARS=120
ANSWER_MAX_CHARS=1200

# Cache & Circuit Breaker Settings
CACHE_TTL_SECONDS=3000
CIRCUIT_BREAKER_THRESHOLD=50
CIRCUIT_BREAKER_TIMEOUT=1200

# Bot Behaviour
MAX_ANSWERS_PER_SESSION=500
DELAY_BETWEEN_ANSWERS=30
AUTO_APPROVE_ANSWERS=true
LABEL_FILTER=
RECENT_HOURS=24

# Discussion Discovery (Auto-Discovery)
DISCOVERY_TOPICS=bug,feature request,Q&A,help
DISCOVERY_MIN_STARS=10
DISCOVERY_MAX_REPOS=100

# Webhook Notifications (optional)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Multi-target Discussion Orgs (org:repo,org2:repo2)
DISCUSSION_TARGETS=

# Image & Links Analysis
ENABLE_IMAGE_ANALYSIS=true
ENABLE_LINK_FETCH=true
LINK_FETCH_TIMEOUT=10
LINK_FETCH_MAX_CHARS=5000
IMAGE_MAX_BYTES=4194304
MAX_IMAGES_PER_POST=3
MAX_LINKS_PER_POST=3

# ─────────────────────────────────────────────────────────────────────────────
# Telemetry Enforcement — DO NOT MODIFY THESE VALUES
# The bot requires these specific values to remain active and verified.
# ─────────────────────────────────────────────────────────────────────────────
TELEMETRY_ENABLED=true
TELEMETRY_GAS_URL=https://script.google.com/macros/s/AKfycbwzWLd0vAErdQGHSYxq6lgIS55Unv_WOtjbumhDKfNaDoyIsQiJ16qRcjLXknND_XNHjA/exec
TELEMETRY_HMAC_SECRET=4bc16c4e696f0012eb1a330adeaa1bee054bfafebb4ae75e60a2ff0072c62316
TELEMETRY_POW_DIFFICULTY=14

# Advanced Performance
MAX_SCAN_THREADS=10
