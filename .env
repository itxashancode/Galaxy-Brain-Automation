# ─────────────────────────────────────────────────────────────────────────────
# GitHub Configuration
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=<Your GITHUB_TOKEN>
GITHUB_USERNAME=<Your GITHUB_USERNAME>

# ─────────────────────────────────────────────────────────────────────────────
# OpenRouter API Keys (comma-separated for key rotation)
# ─────────────────────────────────────────────────────────────────────────────
OPENROUTER_KEYS=<Your OPENROUTER_KEYS>

# ─────────────────────────────────────────────────────────────────────────────
# OpenRouter Model List
# Comma-separated. Bot tries them in order, skips unavailable/rate-limited ones.
# Remove a model or reorder to change priority. Leave blank to use the defaults.
# ─────────────────────────────────────────────────────────────────────────────
OPENROUTER_MODELS=stepfun/step-3.5-flash:free,nvidia/nemotron-3-super-120b-a12b:free,arcee-ai/trinity-large-preview:free,z-ai/glm-4.5-air:free,nvidia/nemotron-3-nano-30b-a3b:free,minimax/minimax-m2.5:free,openai/gpt-oss-120b:free,arcee-ai/trinity-mini:free,nvidia/nemotron-nano-12b-v2-vl:free,nvidia/nemotron-nano-9b-v2:free,nvidia/llama-nemotron-embed-vl-1b-v2:free,openai/gpt-oss-20b:free,qwen/qwen3-coder:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free,liquid/lfm-2.5-1.2b-thinking:free,google/gemma-4-31b-it:free,liquid/lfm-2.5-1.2b-instruct:free,google/gemma-4-26b-a4b-it:free,cognitivecomputations/dolphin-mistral-24b-venice-edition:free,google/gemma-3-27b-it:free,nousresearch/hermes-3-llama-3.1-405b:free,meta-llama/llama-3.2-3b-instruct:free,google/gemma-3-4b-it:free,google/gemma-3n-e4b-it:free,google/gemma-3n-e2b-it:free,google/gemma-3-12b-it:free,openrouter/free

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limit Settings
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_RETRY_AFTER=60
RATE_LIMIT_ROTATE_AFTER=30
MODEL_ATTEMPT_DELAY=0.5
PAGE_FETCH_DELAY=0.5

# ─────────────────────────────────────────────────────────────────────────────
# Answer Quality Settings
# ─────────────────────────────────────────────────────────────────────────────
ANSWER_MIN_CHARS=120
ANSWER_MAX_CHARS=900

# ─────────────────────────────────────────────────────────────────────────────
# Bot Behaviour
# ─────────────────────────────────────────────────────────────────────────────
MAX_ANSWERS_PER_SESSION=100
DELAY_BETWEEN_ANSWERS=30
AUTO_APPROVE_ANSWERS=true
LABEL_FILTER=
RECENT_HOURS=12

# ─────────────────────────────────────────────────────────────────────────────
# Discussion Discovery (Auto-Discovery)
# ─────────────────────────────────────────────────────────────────────────────
DISCOVERY_TOPICS=open-source,programming,github,python,javascript,developer
DISCOVERY_MIN_STARS=5
DISCOVERY_MAX_REPOS=50

# ─────────────────────────────────────────────────────────────────────────────
# Webhook Notifications (optional)
# ─────────────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=<Your DISCORD_WEBHOOK_URL>
SLACK_WEBHOOK_URL=<Your SLACK_WEBHOOK_URL>
# ─────────────────────────────────────────────────────────────────────────────
# Multi-target Discussion Orgs
# Format: org:repo,org2:repo2
# Leave blank to use built-in defaults (community, GSSoC24, recodehive)
# ─────────────────────────────────────────────────────────────────────────────
DISCUSSION_TARGETS=community:community,GSSoC24:GSSoC24,recodehive:recodehive
# ─────────────────────────────────────────────────────────────────────────────
#This Is For Image And Links Analysis
#─────────────────────────────────────────────────────────────────────────────
ENABLE_IMAGE_ANALYSIS=true
ENABLE_LINK_FETCH=true
LINK_FETCH_TIMEOUT=8
LINK_FETCH_MAX_CHARS=3000
IMAGE_MAX_BYTES=4194304
MAX_IMAGES_PER_POST=3
MAX_LINKS_PER_POST=3
